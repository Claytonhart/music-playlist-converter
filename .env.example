# Mock layer toggle (see src/config.js).
#
# Mock is ON by default — the app fakes all OAuth + playlist/track data so the
# full convert flow works with no API keys or network. Set this to "false" to
# exercise the real (now non-functional) network code paths.
#
# To use: copy this file to `.env` and adjust as needed.
VITE_MOCK=true

# --- Napster credentials (only used when VITE_MOCK=false) ---
# These were originally hardcoded in source (a real client secret committed to
# a public repo — see the note in src/auth/napsterTokenFromCode.js). The secret
# has been revoked. A client secret should never live in frontend code at all;
# the proper fix is a backend proxy that performs the OAuth token exchange.
VITE_NAPSTER_API_KEY=
VITE_NAPSTER_API_SECRET=
